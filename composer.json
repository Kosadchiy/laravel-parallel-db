{
    "name": "kosadchiy/laravel-parallel-db",
    "description": "Laravel package for in-process parallel SQL execution via native pgsql/mysqli async APIs.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "database",
        "parallel",
        "async",
        "postgresql",
        "mysql"
    ],
    "homepage": "https://github.com/Kosadchiy/laravel-parallel-db",
    "support": {
        "issues": "https://github.com/Kosadchiy/laravel-parallel-db/issues",
        "source": "https://github.com/Kosadchiy/laravel-parallel-db"
    },
    "require": {
        "php": "^8.3",
        "ext-ctype": "*",
        "illuminate/database": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symplify/easy-coding-standard": "^13.0",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan": "^2.1",
        "orchestra/testbench": "^10.0"
    },
    "suggest": {
        "ext-pgsql": "Required for PostgreSQL async execution",
        "ext-mysqli": "Required for MySQL async execution"
    },
    "autoload": {
        "psr-4": {
            "Kosadchiy\\LaravelParallelDb\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kosadchiy\\LaravelParallelDb\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kosadchiy\\LaravelParallelDb\\LaravelParallelDbServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "lint": [
            "./vendor/bin/ecs check ."
        ],
        "lint-fix": [
            "./vendor/bin/ecs check . --fix --memory-limit=2G"
        ],
        "phpstan": [
            "./vendor/bin/phpstan analyse --memory-limit 2G"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
